docker.enabled = false

apptainer {
    enabled = true
    autoMounts = true
    cacheDir = System.getenv('TITAN_APPTAINER_CACHEDIR') ?: "${projectDir}/.apptainer-cache"
    envWhitelist = 'APPTAINER_CACHEDIR,SINGULARITY_CACHEDIR,APPTAINER_TMPDIR,SINGULARITY_TMPDIR'
    pullTimeout = '2 h'
}

singularity {
    envWhitelist = 'APPTAINER_CACHEDIR,SINGULARITY_CACHEDIR,APPTAINER_TMPDIR,SINGULARITY_TMPDIR'
}

params.egapx_executor = 'singularity'

// External data directories passed through params are not staged by Nextflow,
// so optional branches bind them explicitly when they are enabled.
process {
    withName: validate_inputs {
        containerOptions = {
            [
                projectDir,
                params.eggnog_data_dir,
                params.helixer_model_dir,
                params.interproscan_data_dir,
                params.busco_data_dir,
                params.rfam_data_dir,
                params.omark_data_dir,
                params.cpat_model_dir
            ]
            .findAll { it && it.toString() != 'false' }
            .collect { "--bind ${it}:${it}" }
            .join(' ')
        }
    }
    withName: helixer_prediction {
        containerOptions = {
            def bind = (params.helixer_model_dir && params.helixer_model_dir.toString() != 'false') ? "--bind ${params.helixer_model_dir}:${params.helixer_model_dir}" : ''
            def gpu = params.helixer_use_gpu ? '--nv' : ''
            [gpu, bind].findAll { it }.join(' ')
        }
    }
    withName: eggnog_mapper {
        containerOptions = {
            (params.eggnog_data_dir && params.eggnog_data_dir.toString() != 'false') ? "--bind ${params.eggnog_data_dir}:${params.eggnog_data_dir}" : ''
        }
    }
    withName: interproscan {
        containerOptions = {
            (params.interproscan_data_dir && params.interproscan_data_dir.toString() != 'false') ? "--bind ${params.interproscan_data_dir}:/opt/interproscan/data" : ''
        }
    }
    // Give HISAT2 a task-private /tmp for its named pipes.
    withName: hisat2_alignment {
        containerOptions = { "--bind ${task.workDir}:/tmp" }
    }
    withName: busco {
        containerOptions = {
            (params.busco_data_dir && params.busco_data_dir.toString() != 'false') ? "--bind ${params.busco_data_dir}:${params.busco_data_dir}" : ''
        }
    }
    // The actual process name is infernal_rfam_search (modules/infernal_rfam.nf);
    // this selector previously read "infernal_rfam" and matched nothing, so
    // rfam_data_dir was never bind-mounted and every real run_rfam=true run
    // failed with "rfam_data_dir must contain Rfam.cm and Rfam.clanin" as soon
    // as it reached this process - found running production with run_rfam
    // enabled for the first time.
    withName: infernal_rfam_search {
        containerOptions = {
            (params.rfam_data_dir && params.rfam_data_dir.toString() != 'false') ? "--bind ${params.rfam_data_dir}:${params.rfam_data_dir}" : ''
        }
    }
    withName: omark {
        containerOptions = {
            (params.omark_data_dir && params.omark_data_dir.toString() != 'false') ? "--bind ${params.omark_data_dir}:${params.omark_data_dir}" : ''
        }
    }
    withName: lncrna_candidate_annotation {
        containerOptions = {
            (params.cpat_model_dir && params.cpat_model_dir.toString() != 'false') ? "--bind ${params.cpat_model_dir}:${params.cpat_model_dir}" : ''
        }
    }
    // Give tRNAscan-SE a task-private scratch directory.
    withName: trnascan_se {
        containerOptions = { "--bind ${task.workDir}:/tmp" }
    }
}
