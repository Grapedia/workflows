docker.enabled = false

apptainer {
    enabled = true
    autoMounts = true
    cacheDir = System.getenv('TITAN_APPTAINER_CACHEDIR') ?: "${projectDir}/.apptainer-cache"
    envWhitelist = 'APPTAINER_CACHEDIR,SINGULARITY_CACHEDIR,APPTAINER_TMPDIR,SINGULARITY_TMPDIR'
    pullTimeout = '2 h'
}

singularity {
    envWhitelist = 'APPTAINER_CACHEDIR,SINGULARITY_CACHEDIR,APPTAINER_TMPDIR,SINGULARITY_TMPDIR'
}

params.egapx_executor = 'singularity'
