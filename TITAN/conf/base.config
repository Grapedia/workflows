process {
    errorStrategy = 'terminate'
    cpus = 2
    memory = 4.GB
    time = 2.h

    withLabel: process_low {
        cpus = 1
        memory = 2.GB
        time = 1.h
        maxForks = 4
    }

    // Reserved generic labels for future modules and site-specific overrides.
    // Active TITAN modules should prefer the domain-specific labels below.
    withLabel: process_medium {
        cpus = 4
        memory = 16.GB
        time = 4.h
        maxForks = 2
    }

    withLabel: process_high {
        cpus = 8
        memory = 64.GB
        time = 24.h
        maxForks = 1
    }

    withLabel: process_index {
        cpus = 8
        memory = 32.GB
        time = 8.h
        maxForks = 2
    }

    withLabel: process_alignment {
        cpus = 8
        memory = 48.GB
        time = 12.h
        maxForks = 8
    }

    withLabel: process_transcriptome {
        cpus = 8
        memory = 32.GB
        time = 12.h
        maxForks = 8
    }

    withLabel: process_prediction {
        cpus = 16
        memory = 96.GB
        time = 72.h
        maxForks = 1
    }

    withLabel: process_merge {
        cpus = 4
        memory = 16.GB
        time = 8.h
        maxForks = 4
    }

    withLabel: process_aegis {
        cpus = 4
        memory = 32.GB
        time = 12.h
        maxForks = 1
    }

    withName: EDTA {
        cpus = { params.edta_cpus as int }
    }

    withName: egapx {
        cpus = { params.egapx_cpus as int }
        errorStrategy = 'retry'
        maxRetries = 2
    }

    withName: diamond2go {
        cpus = { params.diamond2go_cpus as int }
    }

    withName: eggnog_mapper {
        cpus = { params.eggnog_mapper_cpus as int }
    }

    withName: helixer_prediction {
        cpus = { params.helixer_cpus as int }
    }

    withName: prepare_RNAseq_fastq_files_short {
        errorStrategy = 'retry'
        maxRetries = { params.ena_process_max_retries as int }
    }

    withName: prepare_RNAseq_fastq_files_long {
        errorStrategy = 'retry'
        maxRetries = { params.ena_process_max_retries as int }
    }
}
