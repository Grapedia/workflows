process.executor = 'local'

docker {
    enabled = true
}

apptainer {
    enabled = false
}

params.egapx_executor = 'docker'

// External data directories passed through params are not staged by Nextflow,
// so optional branches bind them explicitly when they are enabled.
process {
    withName: validate_inputs {
        containerOptions = {
            [
                projectDir,
                params.eggnog_data_dir,
                params.helixer_model_dir,
                params.interproscan_data_dir,
                params.busco_data_dir,
                params.rfam_data_dir,
                params.omark_data_dir,
                params.cpat_model_dir
            ]
            .findAll { it && it.toString() != 'false' }
            .collect { "-v ${it}:${it}" }
            .join(' ')
        }
    }
    withName: helixer_prediction {
        containerOptions = {
            def bind = (params.helixer_model_dir && params.helixer_model_dir.toString() != 'false') ? "-v ${params.helixer_model_dir}:${params.helixer_model_dir}" : ''
            def gpu = params.helixer_use_gpu ? '--gpus all' : ''
            [gpu, bind].findAll { it }.join(' ')
        }
    }
    withName: eggnog_mapper {
        containerOptions = {
            (params.eggnog_data_dir && params.eggnog_data_dir.toString() != 'false') ? "-v ${params.eggnog_data_dir}:${params.eggnog_data_dir}" : ''
        }
    }
    withName: interproscan {
        containerOptions = {
            (params.interproscan_data_dir && params.interproscan_data_dir.toString() != 'false') ? "-v ${params.interproscan_data_dir}:/opt/interproscan/data" : ''
        }
    }
    withName: busco {
        containerOptions = {
            (params.busco_data_dir && params.busco_data_dir.toString() != 'false') ? "-v ${params.busco_data_dir}:${params.busco_data_dir}" : ''
        }
    }
    withName: infernal_rfam_search {
        containerOptions = {
            (params.rfam_data_dir && params.rfam_data_dir.toString() != 'false') ? "-v ${params.rfam_data_dir}:${params.rfam_data_dir}" : ''
        }
    }
    withName: omark {
        containerOptions = {
            (params.omark_data_dir && params.omark_data_dir.toString() != 'false') ? "-v ${params.omark_data_dir}:${params.omark_data_dir}" : ''
        }
    }
    withName: lncrna_candidate_annotation {
        containerOptions = {
            (params.cpat_model_dir && params.cpat_model_dir.toString() != 'false') ? "-v ${params.cpat_model_dir}:${params.cpat_model_dir}" : ''
        }
    }
}
