process.executor = 'slurm'

params.slurm_queue = params.slurm_queue ?: System.getenv('TITAN_SLURM_QUEUE') ?: ''
params.slurm_account = params.slurm_account ?: System.getenv('TITAN_SLURM_ACCOUNT') ?: ''
params.slurm_qos = params.slurm_qos ?: System.getenv('TITAN_SLURM_QOS') ?: ''
params.slurm_export_env = params.slurm_export_env ?: System.getenv('TITAN_SLURM_EXPORT_ENV') ?: ''
params.slurm_submit_rate_limit = params.slurm_submit_rate_limit ?: System.getenv('TITAN_SLURM_SUBMIT_RATE_LIMIT') ?: '10 sec'
params.slurm_queue_size = params.slurm_queue_size ?: System.getenv('TITAN_SLURM_QUEUE_SIZE') ?: 50

process {
    queue = params.slurm_queue ?: null
    clusterOptions = [
        params.slurm_account ? "--account=${params.slurm_account}" : '',
        params.slurm_qos ? "--qos=${params.slurm_qos}" : '',
        params.slurm_export_env ?: ''
    ].findAll { it }.join(' ')
}

executor {
    submitRateLimit = params.slurm_submit_rate_limit
    queueSize = params.slurm_queue_size as int
}
