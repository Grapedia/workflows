env {
  APPTAINER_CACHEDIR = "${projectDir}/.apptainer-cache"
  SINGULARITY_CACHEDIR = "${projectDir}/.apptainer-cache"
  APPTAINER_TMPDIR = "${projectDir}/.apptainer-tmp"
  SINGULARITY_TMPDIR = "${projectDir}/.apptainer-tmp"
  NXF_HOME = "${projectDir}/.nextflow-home"
  TMPDIR = "${projectDir}/.tmp"
  PYTHONNOUSERSITE = '1'
  DEBUGINFOD_URLS = '/dev/null'
}

apptainer {
  envWhitelist = 'APPTAINER_CACHEDIR,SINGULARITY_CACHEDIR,APPTAINER_TMPDIR,SINGULARITY_TMPDIR,TMPDIR,PYTHONNOUSERSITE,DEBUGINFOD_URLS'
}

singularity {
  envWhitelist = 'APPTAINER_CACHEDIR,SINGULARITY_CACHEDIR,APPTAINER_TMPDIR,SINGULARITY_TMPDIR,TMPDIR,PYTHONNOUSERSITE,DEBUGINFOD_URLS'
}

params {
  output_dir = "${projectDir}/data/titan_prod_out"
  previous_assembly = "${projectDir}/data/assemblies/v4_genome_ref.fasta"
  new_assembly = "${projectDir}/data/assemblies/T2T_ref.fasta"
  previous_annotations = "${projectDir}/data/annotations/v4_3_just_ref.gff3"
  RNAseq_samplesheet = "${projectDir}/data/RNAseq_data/RNAseq_samplesheet.csv"
  RNAseq_data_dir = "${projectDir}/data/RNAseq_data"
  protein_samplesheet = "${projectDir}/data/protein_data/samplesheet.csv"
  egapx_paramfile = "${projectDir}/data/egapx/input_PN40024.yaml"
  edta_cpus = 32
  egapx_cpus = 32
  egapx_python = "python3"
  egapx_data_version = "egapxsupportdata_20251017"
  egapx_config_dir = "${projectDir}/data/egapx_config"
  diamond2go_cpus = 16
  run_eggnog_mapper = true
  eggnog_data_dir = "${projectDir}/.eggnog_data"
  eggnog_mapper_cpus = 16
  run_helixer = true
  helixer_model_dir = "${projectDir}/.helixer_models"
  helixer_model = "land_plant"
  helixer_use_gpu = false
  helixer_cpus = 16
  run_interproscan = true
  interproscan_data_dir = "${projectDir}/.interproscan_data"
  interproscan_cpus = 16
  // eudicotyledons_odb12.2 lineage staged into busco_data_dir via
  // `busco --download eudicotyledons_odb12.2 --download_path
  // ${projectDir}/.busco_data` (BUSCO 6.1.0/OrthoDB v12 - the older
  // eudicots_odb10 name from BUSCO v3-5 is not available for plant clades in
  // this pinned version).
  run_busco = true
  busco_data_dir = "${projectDir}/.busco_data"
  busco_lineage = "eudicotyledons_odb12.2"
  busco_cpus = 16
  // Optional ncRNA, lncRNA and alternative final-annotation phases for the
  // production graph. Offline reference data are staged through the matching
  // scripts before enabling the branches that require them.
  run_trnascan = true
  run_rfam = true
  rfam_data_dir = "${projectDir}/.rfam_data"
  run_lncrna = true
  run_mikado = true
  run_flair = true
  run_sqanti3 = true
  run_omark = true
  omark_data_dir = "${projectDir}/.omark_data"
  ena_retry_wait_seconds = 60
  ena_process_max_retries = 2
  publish_intermediates = true
  slurm_queue_size = 20
  slurm_submit_rate_limit = '10 sec'
  // "calcul" must never receive jobs; only these nodes are allowed to run TITAN tasks.
  slurm_nodelist = 'node001,node003,node004,node005'
  // node005 has ~117.8GB RAM, less than several labels below request. On this
  // Slurm cluster, every node in an explicit --nodelist must satisfy the
  // requested resources. Labels above that threshold use this narrower list.
  slurm_nodelist_high_mem = 'node001,node003,node004'
  // process_prediction requests 32 cpus by default (EDTA, egapx,
  // braker3_prediction[_with_long_reads] all use it uncapped). Of the high
  // memory nodes above, only node003 has 32 CPUs; this label needs a
  // single-node list that satisfies both CPU and memory requests.
  slurm_nodelist_prediction = 'node003'
  slurm_export_env = "--nodes=1 --ntasks=1 --export=ALL,APPTAINER_CACHEDIR=${projectDir}/.apptainer-cache,SINGULARITY_CACHEDIR=${projectDir}/.apptainer-cache,APPTAINER_TMPDIR=${projectDir}/.apptainer-tmp,SINGULARITY_TMPDIR=${projectDir}/.apptainer-tmp,TMPDIR=${projectDir}/.tmp,PYTHONNOUSERSITE=1,DEBUGINFOD_URLS=/dev/null"
}

process {
  // --nodes=1 --ntasks=1 are required here: Nextflow's own generated sbatch
  // script never sets them itself (only -c <cpus>), and on this cluster,
  // passing a multi-entry --nodelist without an explicit --nodes=1 makes
  // Slurm allocate ONE NODE PER LISTED NODE (and one task per node) instead
  // of picking a single node from the list.
  clusterOptions = "${params.slurm_export_env} --nodelist=${params.slurm_nodelist}"

  // Real-time progress visibility without -with-trace/-with-timeline/-with-report:
  // those three all require `ps` inside every task's execution context to
  // sample runtime metrics, which none of TITAN's container images ship and
  // Apptainer does not provide from the host filesystem.
  // beforeScript/afterScript are different: Nextflow runs them on the
  // compute-node HOST, outside the container, specifically so they can rely
  // on host tools regardless of what's inside the image. A plain date/echo
  // here needs no procps and afterScript still records task completion when a
  // task exits non-zero. Tail this file to see what's actually running/done:
  //   tail -f data/titan_prod_out/nextflow_reports/progress.log
  beforeScript = { "echo \"\$(date '+%Y-%m-%d %H:%M:%S') STARTED  ${task.process} [${task.tag}]\" >> '${params.output_dir}/nextflow_reports/progress.log'" }
  afterScript  = { "echo \"\$(date '+%Y-%m-%d %H:%M:%S') FINISHED ${task.process} [${task.tag}]\" >> '${params.output_dir}/nextflow_reports/progress.log'" }

  withLabel: process_low { cpus = 2; memory = 8.GB; time = 4.h; maxForks = 8 }
  // fastp only needs to stream reads through a couple of threads (a few GB of
  // RAM), unlike real alignment/index jobs. Keeping it below the alignment
  // label avoids wasting high-memory slots on lightweight trimming tasks.
  withLabel: process_trim { cpus = 8; memory = 16.GB; time = 8.h; maxForks = 12 }
  withLabel: process_medium { cpus = 8; memory = 32.GB; time = 12.h; maxForks = 4 }
  withLabel: process_high { cpus = 16; memory = 96.GB; time = 36.h; maxForks = 2 }
  // maxForks lowered from 12 to 6 for process_alignment/process_transcriptome:
  // at 96GB each, 12 concurrent tasks can exceed the usable memory of the
  // allowed node pool before counting index, prediction and high-memory work.
  // 6 keeps headroom for those labels.
  withLabel: process_alignment { cpus = 16; memory = 96.GB; time = 24.h; maxForks = 6 }
  withLabel: process_transcriptome { cpus = 16; memory = 96.GB; time = 24.h; maxForks = 6 }
  withLabel: process_merge { cpus = 8; memory = 64.GB; time = 24.h; maxForks = 4 }
  withLabel: process_aegis { cpus = 16; memory = 96.GB; time = 36.h; maxForks = 1 }

  // These three exceed node005's RAM (see slurm_nodelist_high_mem above), so
  // they override clusterOptions with the narrower 3-node list.
  withLabel: process_index {
    cpus = 16; memory = 128.GB; time = 24.h; maxForks = 2
    clusterOptions = "${params.slurm_export_env} --nodelist=${params.slurm_nodelist_high_mem}"
  }
  withLabel: process_prediction {
    cpus = 32; memory = 224.GB; time = 120.h; maxForks = 1
    clusterOptions = "${params.slurm_export_env} --nodelist=${params.slurm_nodelist_prediction}"
  }

  // Helixer only needs helixer_cpus (16, see below), so it fits the broader
  // 3-node high-mem list rather than being pinned to node003 alone like the
  // rest of the (uncapped, 32-cpu) process_prediction label.
  withName: helixer_prediction {
    clusterOptions = "${params.slurm_export_env} --nodelist=${params.slurm_nodelist_high_mem}"
  }

  // InterProScan with all analyses on the full protein set is the heaviest
  // of the AEGIS-derived functional annotation steps; give it more headroom
  // than the shared process_aegis label default. Adjust if it still runs out
  // of time/memory on your data.
  withName: interproscan {
    memory = 128.GB; time = 72.h
    clusterOptions = "${params.slurm_export_env} --nodelist=${params.slurm_nodelist_high_mem}"
  }
}
