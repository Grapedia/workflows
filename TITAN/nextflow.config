// Manifest section: Defines metadata about the pipeline
manifest {
  author = 'David Navarro (david.navarro.paya@gmail.com), Antonio Santiago (antsanpaj@gmail.com), Amandine Velt (amandine.velt@inrae.fr)'
  name = 'TITAN (The Intensive Transcript ANnotation pipeline)'
  version = '1.0'
  description = 'Gene annotation pipeline'
  homePage = 'https://github.com/Grapedia/workflows/tree/main/TITAN'
  nextflowVersion = '24.04.3'
  mainScript = 'main.nf'
}

includeConfig 'conf/base.config'

// Parameters section: Defines user-configurable parameters
params {
  output_dir = false
  previous_assembly = false
  new_assembly = false
  previous_annotations = false
  RNAseq_samplesheet = false
  RNAseq_data_dir = false
  protein_samplesheet = false
  egapx_paramfile = false
  publish_intermediates = true
  edta_cpus = 5
  egapx_cpus = 5
  egapx_version = "0.5.2"
  egapx_revision = "v0.5.2"
  container_agat = "quay.io/biocontainers/agat@sha256:7ea8fa5a8428758cd87e3a5dcfaf277febdfcae95cd1fe473770abf8b928ec99"
  container_aegis = "tomsbiolab/aegis@sha256:de88470b3fb4fbab3ff2d5fa0fb9fed36b55952d1e383d3fdb2f5a3a530d84e6"
  container_braker3 = "avelt/braker3@sha256:e69a9aaaafa81e4da5b2bbb98ae120d873018ae40453630f60051ecd5f622c44"
  container_diamond2go = "avelt/diamond2go@sha256:40f1063307f98a2357d60b306bd7d79b6088591c1613e6552613da24002e8360"
  container_eggnog_mapper = "quay.io/biocontainers/eggnog-mapper@sha256:f70babaf681ff4b6b2fc8e8e76754bf989f01dd4910ca91f156c22aa88ea70d3"
  container_helixer = "docker.io/gglyptodon/helixer-docker@sha256:e2294eb2c282c35b919933daa0d6c145b635bfac8b717dbff88e88accbde4303"
  container_interproscan = "docker.io/interpro/interproscan@sha256:dc58b7c147fbbf00c2dd4f5ced42121fc1e8841fcbc7cc2c484380248ff76d11"
  container_edta = "quay.io/biocontainers/edta@sha256:793cbb17bc0569e01caa0c83ad8d1756a394c2ee47b3f512ad4077bc3e422579"
  container_egapx = "ncbi/egapx@sha256:bc657b232d93364d5f3b75ad3bfaf14b6267e46173672b609f26078d48a04298"
  container_fastp = "quay.io/biocontainers/fastp@sha256:0bdf8d8254fc86dd9038551d68dbcb72562e65560b9ce0ea08c1329d2f8587b4"
  container_gffcompare = "avelt/gffcompare@sha256:bd411c13352a2545641c8c34b701030b3977056696607e85b4e86c876d10a82c"
  container_hisat2 = "avelt/hisat2@sha256:022933fd0d30fe9fdfd83c175f7e41d480608fe0264b59f2861babaf7050a722"
  container_liftoff = "quay.io/biocontainers/liftoff@sha256:460d5e82b0c59e8348633f3e0b9a19cf29f9227f7457e90bd7f1d1a2403b3555"
  container_minimap2_samtools = "avelt/minimap2_samtools@sha256:70dcb87bb8021c90fc5eb660bbe1e6fc6bedadbf85c552c66704d27957b1f4ba"
  container_psiclass_samtools = "avelt/psiclass_samtools@sha256:5cad8ecfd81293287bb6612ac8a6daaf17e626339016d326cf79615606acb285"
  container_python = "docker.io/library/python@sha256:57cd7c3a7a273101a6485ba99423ee568157882804b1124b4dd04266317710de"
  container_salmon = "quay.io/biocontainers/salmon@sha256:71ffc3b4961971159a6a2327d55686fb499c43335644ea5623476a082e826fc0"
  container_star = "quay.io/biocontainers/star@sha256:f5910f39a9f5bc171a51fe7400d33e7586cb353c47d759a7c190562322150067"
  container_stringtie = "avelt/stringtie@sha256:856395c26e0c36544ef5c66e24badcac4f68fd5fa51864a0f964a737250545bb"
  container_busco = "quay.io/biocontainers/busco@sha256:d55ad622a5cafcd63c42fc309108688ab255bb9586ee756a5149e249d418c8bd"
  container_multiqc = "quay.io/biocontainers/multiqc@sha256:b65e3fe879df27b92334dda0fd987a6e21bdee09a2848551d4f287099a93b7ac"
  container_trnascan = "quay.io/biocontainers/trnascan-se@sha256:e573090368974ff1228e6894828c6c8a132dfecc3198f5e9fb76832f8f434f29"
  container_infernal = "quay.io/biocontainers/infernal@sha256:05ae1ca6cc76c27180524bc38c5b1e17adf9377be5b8c644d3e8e707848d4d99"
  egapx_executor = "docker"
  egapx_python = "python3"
  egapx_data_version = "current_1"
  egapx_runner_dir = false
  egapx_local_cache_dir = false
  egapx_config_dir = false
  aegis_version = "v0.3.25"
  aegis_gene_id_prefix = "Vitvi"
  diamond2go_cpus = 5
  eggnog_mapper_cpus = 5
  eggnog_mapper_sensmode = "sensitive"
  eggnog_mapper_tax_scope = false
  run_eggnog_mapper = false
  eggnog_data_dir = false
  helixer_cpus = 5
  helixer_model = "land_plant"
  helixer_model_dir = false
  helixer_use_gpu = false
  run_helixer = false
  interproscan_cpus = 5
  run_interproscan = false
  interproscan_data_dir = false
  busco_cpus = 5
  run_busco = false
  busco_lineage = "eudicotyledons_odb12.2"
  busco_data_dir = false
  run_trnascan = false
  run_rfam = false
  rfam_data_dir = false
  ena_download_timeout_seconds = 300
  ena_max_download_attempts = 3
  ena_retry_wait_seconds = 60
  ena_process_max_retries = 2
  ena_verify_md5 = true
  // PsiClass options to decrease the monoexon genes number
  PSICLASS_vd_option = 5.0 // FLOAT : the minimum average coverage depth of a transcript to be reported
  PSICLASS_c_option = 0.03 // FLOAT: only use the subexons with classifier score <= than the given number
  STAR_genomeSAindexNbases = false
  STAR_sjdbGTFfile = false
}

// Temporary backwards-compatible aliases. Prefer --container_egapx and
// --container_aegis in new runs; legacy --egapx_container and
// --aegis_container still override the canonical values.
params.container_egapx = params.egapx_container ?: params.container_egapx
params.egapx_container = params.container_egapx
params.container_aegis = params.aegis_container ?: params.container_aegis
params.aegis_container = params.container_aegis

profiles {
  local {
    includeConfig 'conf/local.config'
  }
  test {
    includeConfig 'conf/test.config'
  }
  apptainer {
    includeConfig 'conf/apptainer.config'
  }
  slurm {
    includeConfig 'conf/slurm.config'
  }
}
