process.executor = 'local'

docker {
  enabled = true
}

params {
  output_dir = "${projectDir}/test-results/realistic-lite"
  previous_assembly = "${projectDir}/test-data/realistic-lite/reference.fa"
  new_assembly = "${projectDir}/test-data/realistic-lite/target.fa"
  previous_annotations = "${projectDir}/test-data/realistic-lite/reference.gff3"
  RNAseq_samplesheet = "${projectDir}/test-data/realistic-lite/RNAseq_samplesheet.csv"
  RNAseq_data_dir = "${projectDir}/test-data/realistic-lite/rnaseq"
  protein_samplesheet = "${projectDir}/test-data/realistic-lite/protein_samplesheet.csv"
  egapx_paramfile = "${projectDir}/test-data/realistic-lite/input_egapx.yaml"
  egapx_runner_dir = "${projectDir}/.egapx_runner"
  egapx_local_cache_dir = "${projectDir}/.egapx_cache"
  edta_cpus = 2
  egapx_cpus = 2
  diamond2go_cpus = 2
  ena_retry_wait_seconds = 0
}

process {
  cpus = 2
  memory = 6.GB
  time = 4.h
  withLabel: process_low { cpus = 1; memory = 2.GB; time = 1.h }
  withLabel: process_medium { cpus = 2; memory = 4.GB; time = 2.h }
  withLabel: process_high { cpus = 2; memory = 6.GB; time = 4.h }
  withLabel: process_index { cpus = 2; memory = 4.GB; time = 2.h }
  withLabel: process_alignment { cpus = 2; memory = 4.GB; time = 2.h }
  withLabel: process_transcriptome { cpus = 2; memory = 4.GB; time = 2.h }
  withLabel: process_prediction { cpus = 2; memory = 6.GB; time = 8.h }
  withLabel: process_merge { cpus = 2; memory = 4.GB; time = 2.h }
  withLabel: process_aegis { cpus = 2; memory = 6.GB; time = 4.h }
}
